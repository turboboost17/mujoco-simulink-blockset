# Default files to ignore from MATLAB
*.asv
*.autosave
*.bak
*.bak_*
# Transient pre-swap copies of binaries / models (e.g. mujoco.dll.old,
# mj_sfun.mexw64.old, mjLib.slx.old). install.m's rename-then-copy
# trick uses these when the primary file is locked by another MATLAB.
*.old
*.old_*
# MEX binaries and PDB debug symbols — never tracked; install.m builds
# them locally or fetches them from the MuJoCo release.
*.mex*
*.mexw64
*.mexa64
*.mexi64
*.mexmaci64
*.mexmaca64
*.pdb

# MuJoCo binary distributions fetched by install.m — keep the parent
# folder (lib/linux-*/mujoco/.gitkeep is tracked) but ignore contents.
lib/linux-aarch64/mujoco/*
!lib/linux-aarch64/mujoco/.gitkeep
lib/linux-x86_64/mujoco/*
!lib/linux-x86_64/mujoco/.gitkeep
# Windows binaries: the full lib/win64/ tree is ignored below by the
# legacy `win64/` rule; install.m fetches them on first use.

BF_RESULT/
temp/
model_report.htmx

CP_result/
BP_result/
*.r2021b
*.r2022a
*.r2021a
.vs/
.vscode/
win64/
glnxa64/
maci64/
maca64/
arm64/
