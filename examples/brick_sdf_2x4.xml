<mujoco model="brick_sdf_2x4">
  <compiler autolimits="true"/>

  <extension>
    <plugin plugin="mujoco.sdf.brick">
      <instance name="brick_2x4">
        <config key="stud_x" value="2"/>
        <config key="stud_y" value="4"/>
        <config key="height" value="3"/>
      </instance>
    </plugin>
  </extension>

  <option timestep="0.001" gravity="0 0 -9.81" integrator="implicitfast" solver="Newton" iterations="60" tolerance="1e-10" cone="elliptic" impratio="8" sdf_iterations="8" sdf_initpoints="10"/>

  <asset>
    <mesh name="brick_2x4">
      <plugin instance="brick_2x4"/>
    </mesh>
  </asset>

  <default>
    <geom condim="4" solref="0.02 3" solimp="0.95 0.995 0.001 0.5 2" friction="0.6 0.03 0.0001" margin="0.0002"/>
  </default>

  <worldbody>
    <geom name="ground" type="plane" pos="0 0 0" size="0.4 0.4 0.01" rgba="0.2 0.25 0.28 1"/>
    <body name="brick" pos="0 0 0.006">
      <geom name="brick_geom" type="sdf" mesh="brick_2x4" quat="0.70710678 0.70710678 0 0" rgba="0.8 0.05 0.03 1">
        <plugin instance="brick_2x4"/>
      </geom>
    </body>
    <body name="brick_2" pos="0 0.0 0.017">
      <freejoint/>
      <geom name="brick_geom2" type="sdf" mesh="brick_2x4" quat="0.70710678 0.70710678 0 0" rgba="0.2 0.05 0.8 1">
        <plugin instance="brick_2x4"/>
      </geom>
    </body>
    <light name="key" pos="0.2 -0.3 0.5"/>
  </worldbody>
</mujoco>