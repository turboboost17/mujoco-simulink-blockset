<mujoco model="lego_sdf_2x4">
  <compiler autolimits="true"/>

  <extension>
    <plugin plugin="mujoco.sdf.lego_brick">
      <instance name="brick_2x4">
        <config key="stud_x" value="4"/>
        <config key="stud_y" value="2"/>
        <config key="height" value="3"/>
      </instance>
    </plugin>
  </extension>

  <option timestep="0.002" gravity="0 0 -9.81" sdf_iterations="10" sdf_initpoints="20"/>

  <asset>
    <mesh name="brick_2x4">
      <plugin instance="brick_2x4"/>
    </mesh>
  </asset>

  <default>
    <geom solref="0.01 1" solimp="0.95 0.99 0.0001" friction="0.8"/>
  </default>

  <worldbody>
    <geom name="ground" type="plane" pos="0 0 0" size="0.4 0.4 0.01" rgba="0.2 0.25 0.28 1"/>
    <body name="brick" pos="0 0 0.04">
      <freejoint/>
      <geom name="brick_geom" type="sdf" mesh="brick_2x4" quat="0.70710678 0.70710678 0 0" rgba="0.8 0.05 0.03 1">
        <plugin instance="brick_2x4"/>
      </geom>
    </body>
    <light name="key" pos="0.2 -0.3 0.5"/>
  </worldbody>
</mujoco>